{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "shell",
      "label": "compile",
      "command": "& 'C:\\Program Files\\nodejs\\node.exe' node_modules/typescript/bin/tsc -p ./",
      "problemMatcher": "$tsc",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated"
      }
    },
    {
      "type": "npm",
      "script": "watch",
      "problemMatcher": "$tsc-watch",
      "isBackground": true,
      "group": "build",
      "label": "npm: watch"
    }
  ]
}
